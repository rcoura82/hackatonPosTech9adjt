                "beneficiarios"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Procedimentos",
      "item": [
        {
          "name": "Criar Procedimento",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tussCode\": \"30101012\",\n  \"description\": \"Consulta ambulatorial\",\n  \"type\": \"APAC\",\n  \"baseCost\": 250.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/procedimentos",
              "host": [
