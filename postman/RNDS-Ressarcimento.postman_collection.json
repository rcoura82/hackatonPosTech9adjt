                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "procedimentos"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Autorizacoes AIH APAC ABI",
      "item": [
        {
          "name": "Criar Autorizacao",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"externalCode\": \"AIH-0001\",\n  \"type\": \"APAC\",\n  \"beneficiaryId\": \"{{beneficiaryId}}\",\n  \"operatorId\": \"{{operatorId}}\",\n  \"procedureId\": \"{{procedureId}}\",\n  \"requestedAmount\": 300.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/autorizacoes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "autorizacoes"
              ]
            }
          }
        },
        {
          "name": "Listar Autorizacoes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/autorizacoes?beneficiaryId={{beneficiaryId}}&type=APAC",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "autorizacoes"
              ],
              "query": [
                {
                  "key": "beneficiaryId",
                  "value": "{{beneficiaryId}}"
                },
                {
                  "key": "type",
                  "value": "APAC"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Ressarcimentos",
      "item": [
        {
          "name": "Gerar Ressarcimento",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorizationId\": \"{{authorizationId}}\",\n  \"operatorId\": \"{{operatorId}}\",\n  \"susUnit\": \"SUS-DF-HRAN\",\n  \"amount\": 300.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/ressarcimentos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "ressarcimentos"
              ]
            }
          }
        },
        {
          "name": "Marcar Ressarcimento Como Pago",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/v1/ressarcimentos/{{reimbursementId}}/pagar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "ressarcimentos",
                "{{reimbursementId}}",
                "pagar"
              ]
            }
          }
        },
        {
          "name": "Listar Ressarcimentos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/ressarcimentos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "ressarcimentos"
              ]
            }
          }
        }
      ]
    },
