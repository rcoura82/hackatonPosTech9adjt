              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ansCode\": \"123456\",\n  \"corporateName\": \"Operadora Demo SA\",\n  \"cnpj\": \"11222333000199\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/operadoras",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "operadoras"
              ]
            }
          }
        },
        {
          "name": "Listar Operadoras",
          "request": {
            "method": "GET",
